# Medusa Storefront (Vite)

# Medusa backend URL
VITE_MEDUSA_BACKEND_URL=http://localhost:9000

# Publishable API key (required for Medusa v2 Store API)
VITE_MEDUSA_PUBLISHABLE_KEY=

# Optional: scope product queries to a Sales Channel
# If you generate 1 publishable key per store (recommended), you can leave this empty.
VITE_MEDUSA_SALES_CHANNEL_ID=

# Optional: force mock data on/off
# - true  -> always use mock data
# - false -> always use Medusa API
# If omitted, the app uses mock data until you configure backend url + publishable key.
VITE_USE_MOCK_DATA=true
